<#-- Commands Dialog -->
start-dialog = <b>Привіт! 👋</b>

                Я допоможу вам зв’язатися з власником як <b>напряму</b>, так і <b>анонімно</b>.

                Щоб почати, оберіть одну з кнопок нижче 👇:

help-dialog = <b>Довідка по боту 🆘</b>

            • <b>Пряме повідомлення</b> 💌: ваше повідомлення надійде власнику разом із вашими даними.
            • <b>Анонімне повідомлення</b> 🥷: ваше повідомлення надсилається без розкриття особи.
            • Можна надіслати будь-який контент ( текст, фото, відео, голос тощо ) одним <b>повідомленням</b>.
            • Після розгляду відповідь власника надійде вам автоматично.

            ⚠️ Поки не отримаєте відповідь, не <b>блокуйте</b> бота.

links-dialog = 💠 Мої сторінки в соцмережах:

language-dialog = <b>Будь ласка, оберіть мову 👇</b>
language-changed-dialog = Мову оновлено ✅


<#-- Buttons Dialog -->

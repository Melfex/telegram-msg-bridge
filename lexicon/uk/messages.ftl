<#-- Commands Dialog -->
start-dialog = <b>Привіт! 👋</b>

                Я допоможу вам зв’язатися з власником як <b>напряму</b>, так і <b>анонімно</b>.

                Щоб почати, оберіть одну з кнопок нижче 👇:

help-dialog = <b>Довідка по боту 🆘</b>

            • <b>Пряме повідомлення</b> 💌: ваше повідомлення надійде власнику разом із вашими даними.
            • <b>Анонімне повідомлення</b> 🥷: ваше повідомлення надсилається без розкриття особи.
            • Можна надіслати будь-який контент ( текст, фото, відео, голос тощо ) одним <b>повідомленням</b>.
            • Після розгляду відповідь власника надійде вам автоматично.

            ⚠️ Поки не отримаєте відповідь, не <b>блокуйте</b> бота.

links-dialog = 💠 Мої сторінки в соцмережах:

language-dialog = <b>Будь ласка, оберіть мову 👇</b>
language-changed-dialog = Мову оновлено ✅


<#-- Buttons Dialog -->
message-btn = Пряме повідомлення |💌
anonymous-message-btn = 🥷| Анонімне повідомлення
links-btn = 📟| Мої сторінки
help-btn = Довідка |🆘
language-btn = 💱 Змінити мову 💱

cancel-btn = 🔙| Скасувати
reply-btn = • Відповісти користувачу •
block-btn = 🚫| Заблокувати
unblock-btn = ☑️| Розблокувати



<#-- Messaging Flow -->
send-direct-dialog = <b>Ласкаво просимо 💛.</b>

                    Ви можете надіслати своє повідомлення одним <b>повідомленням</b> у будь-якому форматі ( <tg-spoiler>текст, фото, відео тощо</tg-spoiler> ). Зверніть увагу: ваші дані будуть <b>видимі</b> власнику.

                    Будь ласка, не <b>блокуйте</b> бота до отримання відповіді; також <b>ввічливість</b> обов’язкова.

                    <b>Надішліть своє повідомлення 👇🏻:</b>

send-anon-dialog = <b>Ласкаво просимо 💛.</b>

                    Ви можете надіслати своє повідомлення одним <b>повідомленням</b> у будь-якому форматі ( <tg-spoiler>текст, фото, відео тощо</tg-spoiler> ). Зверніть увагу: ваші дані <b>не будуть видимі</b> власнику.

                    Будь ласка, не <b>блокуйте</b> бота до отримання відповіді; також <b>ввічливість</b> обов’язкова.

                    <b>Надішліть своє повідомлення 👇🏻:</b>

cancelled-dialog = Операцію скасовано, ми повернулися до <b>головного</b> меню.

            Щоб продовжити, оберіть одну з кнопок нижче 👇:

message-delivered-dialog = Ваше повідомлення отримано та надіслано ✅;

                    Будь ласка, наберіться <b>терпіння</b> до отримання остаточної відповіді й <u>не блокуйте бота</u>, адже після блокування ви <u>не</u> отримаєте відповідь.

                    Щоб користуватися ботом, оберіть одну з кнопок нижче 👇🏻:

you-are-blocked-dialog = <b>Шановний користувачу ❕;</b>
                        Ваш акаунт заблоковано, і ви більше не можете користуватися послугами бота.

dont-spam-dialog = <b>Повільніше ‼️ </b>
                    Вас заблоковано на <code>{ $block_duration }</code> секунд за спам.

<#-- Owner Panel -->
panel-dialog = <b>Панель керування 🛠</b>

            Ласкаво просимо, власнику. Оберіть дію нижче 👇:

toggle-bot-btn = 🔌| Увімкнути/вимкнути бота
block-user-btn = 🚫| Заблокувати
unblock-user-btn = ✅| Розблокувати
broadcast-btn = 📢| Розсилка

bot-enabled-dialog = Бот тепер <b>увімкнено</b> ✅
bot-disabled-dialog = Бот тепер <b>вимкнено</b> ⛔️

bot-status-dialog = <b>Статус бота ⚙️</b>

            Виберіть статус бота нижче; поточний позначено зеленим 👇:
bot-status-on-btn = 🟢 Увімкнено
bot-status-off-btn = 🔴 Вимкнено
back-panel-btn = 🔙 Назад до панелі

ask-user-id-dialog = Надішліть <b>числовий ID</b> користувача 👇:
invalid-id-dialog = ⚠️ Невірний ID. Надішліть коректний числовий ID.

broadcast-ask-dialog = Надішліть повідомлення для розсилки всім користувачам 👇:
broadcast-started-dialog = 📢 Розсилку розпочато для <b>{ $total }</b> користувачів…
broadcast-report-dialog = ✅ Розсилку завершено.

            • Надіслано: <b>{ $sent }</b>
            • Помилок: <b>{ $failed }</b>
            • Усього: <b>{ $total }</b>

<#-- Access Gate -->
bot-off-dialog = <b>Бот наразі вимкнено ⛔️</b>

            Будь ласка, спробуйте пізніше.

owner-reply-dialog = 💌•  Ваше повідомлення <b>розглянуто</b> та <b>надано відповідь</b>.

                    📝- Текст відповіді:
                    <blockquote expandable>{ $answer_text }</blockquote>

                    ➖➖➖➖➖➖
                    ⏰ <code>{ $time }</code>



<#-- Owner Inbox -->
inbox-direct-dialog = Шановний власнику, для вас надійшло нове повідомлення;
                    <b>👤- Ім’я:</b><code> { $name } </code>
                    <b>🆔- ID користувача:</b><code> { $user_id } </code>
                    <b>🫆- Ім’я користувача:</b><code> { $user_name } </code>
                    <b>📝- Повідомлення:</b>
                    <blockquote expandable>{ $message }</blockquote>

inbox-anon-dialog = Шановний власнику, для вас надійшло нове анонімне повідомлення;
                    <b>📝- Повідомлення:</b>
                    <blockquote expandable>{ $message }</blockquote>

reply-dialog = Надішліть свою відповідь на це повідомлення одним повідомленням (текст, відео, голос тощо). Щоб скасувати, скористайтеся кнопкою нижче.
reply-sent-dialog = Відповідь успішно надіслано! ✅
user-blocked-dialog = Користувача заблоковано ✅
user-unblocked-dialog = Користувача розблоковано ✅

<#-- Commands Dialog -->
start-dialog = <b>नमस्ते! 👋</b>

                मैं आपको मालिक से <b>सीधे</b> और <b>गुमनाम</b> दोनों तरीकों से संपर्क करने में मदद करता हूँ।

                शुरू करने के लिए, नीचे दिए गए किसी एक बटन को चुनें 👇:

help-dialog = <b>बॉट गाइड 🆘</b>

            • <b>सीधा संदेश</b> 💌: आपका संदेश आपकी पहचान के साथ मालिक तक पहुँचता है।
            • <b>गुमनाम संदेश</b> 🥷: आपका संदेश आपकी पहचान बताए बिना भेजा जाता है।
            • आप कोई भी सामग्री ( टेक्स्ट, फ़ोटो, वीडियो, वॉइस आदि ) <b>एक ही संदेश</b> के रूप में भेज सकते हैं।
            • समीक्षा के बाद, मालिक का उत्तर स्वतः आपको भेज दिया जाता है।

            ⚠️ उत्तर मिलने तक कृपया बॉट को <b>ब्लॉक</b> न करें।

links-dialog = 💠 मेरे सोशल मीडिया पेज:

language-dialog = <b>कृपया अपनी भाषा चुनें 👇</b>
language-changed-dialog = भाषा अपडेट हो गई ✅



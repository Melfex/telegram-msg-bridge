unblock-btn = ☑️| अनब्लॉक करें



<#-- Messaging Flow -->
send-direct-dialog = <b>स्वागत है 💛.</b>

                    आप अपना संदेश किसी भी रूप में <b>एक ही संदेश</b> के रूप में भेज सकते हैं ( <tg-spoiler>टेक्स्ट, फ़ोटो, वीडियो आदि</tg-spoiler> )। ध्यान दें कि आपकी पहचान मालिक को <b>दिखाई देगी</b>।

                    कृपया उत्तर मिलने से पहले बॉट को <b>ब्लॉक</b> न करें; साथ ही <b>शिष्टता</b> भी आवश्यक है।

                    <b>अपना संदेश भेजें 👇🏻:</b>

send-anon-dialog = <b>स्वागत है 💛.</b>

                    आप अपना संदेश किसी भी रूप में <b>एक ही संदेश</b> के रूप में भेज सकते हैं ( <tg-spoiler>टेक्स्ट, फ़ोटो, वीडियो आदि</tg-spoiler> )। ध्यान दें कि आपकी पहचान मालिक को <b>दिखाई नहीं देगी</b>।

                    कृपया उत्तर मिलने से पहले बॉट को <b>ब्लॉक</b> न करें; साथ ही <b>शिष्टता</b> भी आवश्यक है।

                    <b>अपना संदेश भेजें 👇🏻:</b>

cancelled-dialog = कार्रवाई रद्द कर दी गई और हम <b>मुख्य</b> मेनू पर लौट आए।

            जारी रखने के लिए, नीचे दिए गए किसी एक बटन को चुनें 👇:

message-delivered-dialog = आपका संदेश प्राप्त होकर भेज दिया गया ✅;

                    कृपया अंतिम उत्तर मिलने तक <b>धैर्य</b> रखें और <u>बॉट को ब्लॉक न करें</u>, क्योंकि ब्लॉक करने के बाद आपको उत्तर <u>नहीं</u> मिलेगा।

                    बॉट का उपयोग करने के लिए, नीचे दिए गए किसी एक बटन को चुनें 👇🏻:

you-are-blocked-dialog = <b>प्रिय उपयोगकर्ता ❕;</b>
                        आपका खाता ब्लॉक कर दिया गया है और अब आप बॉट की सेवाओं का उपयोग नहीं कर सकते।

owner-reply-dialog = 💌•  आपके संदेश की <b>समीक्षा</b> की गई और <b>उत्तर</b> दिया गया।

                    📝- उत्तर का पाठ:
                    <blockquote expandable>{ $answer_text }</blockquote>

                    ➖➖➖➖➖➖
                    ⏰ <code>{ $time }</code>



<#-- Owner Inbox -->
inbox-direct-dialog = प्रिय मालिक, आपके लिए एक नया संदेश आया है;
                    <b>👤- नाम:</b><code> { $name } </code>
                    <b>🆔- उपयोगकर्ता आईडी:</b><code> { $user_id } </code>
                    <b>🫆- उपयोगकर्ता नाम:</b><code> { $user_name } </code>
                    <b>📝- संदेश:</b>
                    <blockquote expandable>{ $message }</blockquote>

inbox-anon-dialog = प्रिय मालिक, आपके लिए एक नया गुमनाम संदेश आया है;
                    <b>📝- संदेश:</b>
                    <blockquote expandable>{ $message }</blockquote>

reply-dialog = इस संदेश का अपना उत्तर एक ही संदेश (टेक्स्ट, वीडियो, वॉइस आदि) के रूप में भेजें। रद्द करने के लिए नीचे दिए गए बटन का उपयोग करें।
reply-sent-dialog = उत्तर सफलतापूर्वक भेजा गया! ✅
user-blocked-dialog = उपयोगकर्ता ब्लॉक किया गया ✅
user-unblocked-dialog = उपयोगकर्ता अनब्लॉक किया गया ✅
reaction-sent-dialog = प्रतिक्रिया जोड़ी गई ✅
